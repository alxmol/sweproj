# Rust build products are reproducible and can become very large across seven crates.
target/

# Local environment and secret-bearing configuration must never be committed.
.env
.env.*

# BETH is provided out-of-band and is too large for normal Git history.
beth/archive/

# Trained model artifacts are generated by the ML pipeline and may exceed Git limits.
*.onnx
artifacts/*.onnx

# Runtime outputs belong to local development sessions, not source control.
logs/
fuzz/artifacts/
fuzz/corpus/
fuzz/coverage/
fuzz/run_summary.json

# Factory-local project settings are machine-specific orchestration state.
.factory/

# Python virtualenvs (e.g., crates/mini-edr-detection/training/.venv) are local
# environments and must never be committed. Workers should activate via .venv/bin/.
**/.venv/
**/__pycache__/
*.pyc
